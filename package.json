{
  "name": "qelumi-server",
  "version": "4.0.4",
  "description": "Secure Qelumi translation, learning, feedback and administration backend",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test",
    "prewarm": "node scripts/nightly-prewarm.js",
